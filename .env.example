# Server Configuration
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/careerconnect_ai
REDIS_URL=redis://localhost:6379

# JWT Secrets (MUST be at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-required-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-required
JWT_EXPIRE=1d
JWT_REFRESH_EXPIRE=30d

# OAuth (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI Services (Optional)
OPENAI_API_KEY=
GPT_OSS_API_KEY=

# LinkedIn API (Optional)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Google Meet (Optional)
GOOGLE_MEET_API_KEY=
