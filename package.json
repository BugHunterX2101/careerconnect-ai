{
  "name": "careerconnect-ai",
  "version": "2.0.0",
  "description": "AI-powered career platform",
  "main": "src/server/index.js",
  "scripts": {
    "start": "node src/server/index.js",
    "start:cluster": "node src/server/cluster.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "stop:pm2": "pm2 stop careerconnect",
    "restart:pm2": "pm2 restart careerconnect",
    "logs:pm2": "pm2 logs careerconnect",
    "dev": "nodemon src/server/index.js",
    "build:client": "cd src/client && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:load": "node tests/load-test.js",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write \"src/**/*.{js,json}\""
  },
  "dependencies": {
    "@tensorflow/tfjs-node": "^4.11.0",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "bull": "^4.12.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^7.0.1",
    "googleapis": "^128.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.3",
    "multer": "^1.4.5-lts.1",
    "natural": "^8.1.0",
    "openai": "^6.32.0",
    "passport": "^0.6.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-linkedin-oauth2": "^2.0.0",
    "pdf-parse": "^2.4.5",
    "redis": "^4.6.5",
    "sequelize": "^6.35.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.6.1",
    "sql.js": "^1.14.1",
    "uuid": "^9.0.0",
    "validator": "^13.9.0",
    "winston": "^3.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "eslint": "^8.40.0",
    "eslint-config-prettier": "^8.8.0",
    "jest": "^29.5.0",
    "nodemon": "^3.1.11",
    "prettier": "^2.8.8",
    "supertest": "^6.3.3"
  }
}
